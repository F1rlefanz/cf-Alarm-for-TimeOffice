<?xml version="1.0" encoding="utf-8"?>
<network-security-config>
    <!-- 
        SECURITY-HARDENED Network Security Configuration
        
        PRINCIPLE: Minimal cleartext permissions only for Philips Hue Bridge
        SECURITY IMPACT:
        - Cleartext ONLY for local network ranges (192.168.x.x, 10.x.x.x, 172.16-31.x.x)
        - ALL external traffic forced to HTTPS
        - Philips Hue bridges only support HTTP for local API access
        - Physical button press still required for initial authentication
    -->
    
    <!-- Debug configuration: Allow user certificates for development -->
    <debug-overrides cleartextTrafficPermitted="true">
        <trust-anchors>
            <certificates src="system"/>
            <certificates src="user"/>
        </trust-anchors>
    </debug-overrides>
    
    <!-- 
        PRODUCTION: Strict security with minimal cleartext exceptions
        Only allow HTTP for private IP ranges (RFC 1918)
        
        NOTE: Certificate Pinning for Google APIs deliberately EXCLUDED
        Google officially discourages pinning for googleapis.com domains
        due to high risk of breakage during CA migrations.
        See: https://developers.google.com/maps/root-ca-faq
    -->
    <domain-config cleartextTrafficPermitted="true">
        <!-- Class A private network -->
        <domain includeSubdomains="true">10.0.0.0/8</domain>
        <!-- Class B private network -->
        <domain includeSubdomains="true">172.16.0.0/12</domain>
        <!-- Class C private network -->
        <domain includeSubdomains="true">192.168.0.0/16</domain>
        <!-- Link-local addresses -->
        <domain includeSubdomains="true">169.254.0.0/16</domain>
        <!-- Development localhost -->
        <domain includeSubdomains="false">localhost</domain>
        <domain includeSubdomains="false">127.0.0.1</domain>
        <domain includeSubdomains="false">10.0.2.2</domain>
    </domain-config>
    
    <!-- 
        BASE CONFIG: HTTPS enforced for all external traffic
        This is the critical security improvement
    -->
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system"/>
        </trust-anchors>
    </base-config>
</network-security-config>
